<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="150" MinHeight="50" Margin="0"
             x:Class="XentuCreator.UserControls.TerminalControl">
	<Grid>
		<TextBox Name="_tb" BorderBrush="Transparent" IsReadOnly="True" BorderThickness="0" Margin="5" FontFamily="Consolas" Text="$" />		
	</Grid>
</UserControl>
